{
  "name": "web-app-load-testing",
  "version": "1.0.0",
  "private": true,
  "description": "Offline-first heavy React SPA with Fastify mock backend, Playwright E2E, and real-browser Locust load testing",
  "workspaces": [
    "app",
    "api"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=api && uv run playwright install chromium && npx --workspace=app playwright install chromium",
    "dev:api": "npm run dev --workspace=api",
    "dev:app": "npm run dev --workspace=app",
    "build": "npm run build --workspace=app",
    "preview": "npm run preview --workspace=app",
    "typecheck": "npm run typecheck --workspace=app",
    "test:e2e": "npm run test:e2e --workspace=app",
    "test:e2e:ui": "npm run test:e2e:ui --workspace=app",
    "loadtest:ui": "uv run loadtest/locustfile_browser.py --host=http://localhost:5173",
    "loadtest:browser:dev": "uv run loadtest/locustfile_browser.py --host=http://localhost:5173 --headless -u 3 -r 1 -t 1m",
    "loadtest:browser:integration": "uv run loadtest/locustfile_browser.py --host=http://localhost:5173 --headless -u 8 -r 2 -t 3m",
    "verify:offline": "bash scripts/verify-offline.sh",
    "start": "bash scripts/tmux-run.sh",
    "wait": "bash scripts/wait-for-services.sh"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
